# Actually Remote — Secrets Template
# ------------------------------------
# Copy this file to .env and fill in your values.
# .env is gitignored and will never be committed.
#
# These same values must also be added as GitHub Secrets
# so the GitHub Actions workflow can access them.
# Go to: your repo → Settings → Secrets and variables → Actions → New repository secret

# --- AI Provider ---
# Add only the key for the provider you chose in config.yaml

# Google Gemini (default)
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Anthropic Claude (alternative)
# Get your key at: https://console.anthropic.com
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI (alternative)
# Get your key at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=your_openai_api_key_here

# --- Email ---

# Resend (default)
# Get your key at: https://resend.com (free tier: 100 emails/day)
RESEND_API_KEY=your_resend_api_key_here
EMAIL_FROM=onboarding@resend.dev
EMAIL_TO=your@gmail.com

# Gmail (Gmail support coming in a future release)
# You must use an App Password, not your regular Gmail password.
# How to get one: Google Account → Security → 2-Step Verification → App Passwords
# GMAIL_ADDRESS=your@gmail.com
# GMAIL_APP_PASSWORD=your_gmail_app_password_here

# --- Discord (optional) ---
# Uncomment if you enabled Discord in config.yaml
# How to get one: Discord server → Edit Channel → Integrations → Webhooks
# DISCORD_WEBHOOK_URL=your_discord_webhook_url_here

# --- Telegram (optional) ---
# Uncomment if you enabled Telegram in config.yaml
# How to create a bot: message @BotFather on Telegram → /newbot
# TELEGRAM_BOT_TOKEN=your_bot_token_here
# TELEGRAM_CHAT_ID=your_chat_id_here
